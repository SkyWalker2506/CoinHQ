{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledMcpjsonServers": ["github", "git", "atlassian", "context7"],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd backend && uv run pytest --tb=short -q 2>/dev/null || true",
            "async": true,
            "timeout": 120,
            "statusMessage": "Running backend tests..."
          }
        ]
      }
    ]
  }
}
